{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Dev Plan Schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "run_id",
    "tasks"
  ],
  "properties": {
    "run_id": {
      "type": "string"
    },
    "tasks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "title",
          "goal",
          "deps",
          "touched_paths",
          "forbidden_paths",
          "acceptance_ids",
          "parallel_safe",
          "needs_db",
          "needs_ports",
          "verification_commands",
          "evidence_paths",
          "notes"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "goal": {
            "type": "string"
          },
          "deps": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "touched_paths": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "forbidden_paths": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "acceptance_ids": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          },
          "parallel_safe": {
            "type": "boolean"
          },
          "needs_db": {
            "type": "boolean"
          },
          "needs_ports": {
            "type": "array",
            "items": {
              "type": [
                "integer",
                "string"
              ]
            }
          },
          "verification_commands": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "evidence_paths": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "notes": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    }
  }
}